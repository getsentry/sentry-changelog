# rename this file to .env and supply the values listed below
# also make sure they are available to the build tool (e.g. Vercel/Netlify)
# warning: variables prefixed with NEXT_PUBLIC_ will be made available to client-side code
# be careful not to expose sensitive data

# Neon pooled connection string. For local development, use a Neon dev-branch URL
# placed in .env.development.local (gitignored). See the README "Development" section.
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=secret
# Vercel Blob token is auto-configured in Vercel; set locally from Dashboard → Storage → Tokens
BLOB_READ_WRITE_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
